# AutoManager inventory integration
AUTOMANAGER_XML_URL=
INVENTORY_MODE=live-cached
INVENTORY_STATUS_SECRET=
DEALER_TIME_ZONE=America/Denver

# WebManager iframe integration
NEXT_PUBLIC_WEBMANAGER_BASE_URL=https://clients.automanager.com/e90d3789cf7843e0ba9b798f6ce4e87a

# Optional: Google Analytics 4
# Add this in Vercel after creating a GA4 Web data stream.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# SEO / indexing
# Use the final domain here. Keep indexing disabled until the real domain is launched.
NEXT_PUBLIC_SITE_URL=https://www.repeteauto.com
NEXT_PUBLIC_INDEXING_ENABLED=false
