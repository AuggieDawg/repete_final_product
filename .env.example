# AutoManager XML feed.
# Keep this server-side only. Never prefix with NEXT_PUBLIC_.
AUTOMANAGER_XML_URL="https://clients.automanager.com/YOUR_FEED_URL/inventory.xml?ID=YOUR_ID&Features=1&Photos=1"

# fixture = local XML fixture testing
# live-cached = server-side live feed with cache/revalidation behavior
INVENTORY_MODE="fixture"

# Default fallback cache TTL. Business-hour policy can override this.
INVENTORY_CACHE_TTL_SECONDS="3600"

# Optional. Use this to protect diagnostic endpoints later.
INVENTORY_STATUS_SECRET="change-me"

# Dealership timezone.
DEALER_TIME_ZONE="America/Denver"
